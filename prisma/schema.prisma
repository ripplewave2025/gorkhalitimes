generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    guest
    reader
    contributor
    note_writer
    guardian
    admin
}

enum TrustTier {
    A
    B
    C
    D
}

enum RightsMode {
    link_only
    summary_allowed
    partner_full
}

enum StoryStatus {
    active
    developing
    resolved
    archived
}

enum TrustBadge {
    official
    multi_source
    single_source
    developing
    disputed
}

enum AlertStatus {
    active
    updated
    resolved
}

enum NoteStatus {
    draft
    under_review
    published
    rejected
    superseded
}

enum SourceHealthStatus {
    healthy
    degraded
    failing
    unknown
}

enum HelpRequestStatus {
    pending
    in_review
    completed
}

model User {
    id                 String         @id @default(cuid())
    name               String
    phone              String?        @unique
    email              String?        @unique
    role               UserRole       @default(reader)
    languagePreference String         @default("ne")
    hometownOptional   String?
    isPhoneVerified    Boolean        @default(false)
    status             String         @default("active")
    preferences        UserPreference?
    createdAt          DateTime       @default(now())
    updatedAt          DateTime       @updatedAt
}

model UserPreference {
    id                String   @id @default(cuid())
    userId            String   @unique
    uiLanguage        String   @default("ne")
    contentLanguage   String   @default("ne")
    audioLanguage     String   @default("ne")
    fallbackLanguage  String   @default("en")
    preferredPlaces   Json
    preferredTopics   Json
    preferredSources  Json
    mutedSourceIds    Json
    morningAudioDigest Boolean @default(true)
    govtSchemesAlerts Boolean @default(true)
    audioSpeed        Float    @default(1)
    onboardingComplete Boolean @default(false)
    recentSearches    Json
    user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
}

model Source {
    id            String              @id @default(cuid())
    name          String
    type          String
    baseUrl       String
    rssUrl        String?
    extractorUrl  String?
    trustTier     TrustTier
    language      String
    locationScope String
    status        String              @default("active")
    ingestMethod  String?
    rightsMode    RightsMode
    tagsJson      Json?
    createdAt     DateTime            @default(now())
    updatedAt     DateTime            @updatedAt
    items         SourceItem[]
    healthChecks  SourceHealthCheck[]
}

model SourceItem {
    id               String   @id @default(cuid())
    sourceId         String
    externalId       String?
    url              String
    titleRaw         String
    bodyRaw          String?
    imageUrl         String?
    publishedAt      DateTime?
    fetchedAt        DateTime @default(now())
    languageDetected String?
    locationTagsJson Json?
    categoryTagsJson Json?
    contentHash      String?
    status           String   @default("active")
    source           Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model SourceHealthCheck {
    id           String             @id @default(cuid())
    sourceId     String
    status       SourceHealthStatus @default(unknown)
    checkedAt    DateTime           @default(now())
    lastSuccessAt DateTime?
    errorMessage String?
    source       Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model StoryCluster {
    id               String      @id @default(cuid())
    canonicalTitle   String
    summaryShortNe   String
    summaryShortEn   String
    summaryFullNe    String
    summaryFullEn    String
    trustBadge       TrustBadge
    urgencyScore     Float       @default(0)
    relevanceScore   Float       @default(0)
    freshnessScore   Float       @default(0)
    primaryImageUrl  String?
    primaryLocation  String?
    category         String
    status           StoryStatus @default(active)
    firstSeenAt      DateTime    @default(now())
    lastUpdatedAt    DateTime    @updatedAt
}

model StoryAudio {
    id              String   @id @default(cuid())
    clusterId       String
    language        String
    voiceName       String?
    audioUrl        String?
    durationSec     Int?
    textVersionHash String?
    createdAt       DateTime @default(now())
}

model Alert {
    id                String      @id @default(cuid())
    title             String
    body              String
    category          String
    severity          String
    locationScope     String
    status            AlertStatus @default(active)
    sourceUrl         String?
    publishedByUserId String?
    startsAt          DateTime
    endsAt            DateTime?
    createdAt         DateTime    @default(now())
    updatedAt         DateTime    @updatedAt
}

model NoteRequest {
    id               String   @id @default(cuid())
    clusterId        String
    createdByUserId  String?
    reason           String
    detailsNullable  String?
    evidenceUrlNullable String?
    status           String   @default("queued")
    createdAt        DateTime @default(now())
}

model GuardianNote {
    id               String     @id @default(cuid())
    clusterId        String
    authorUserId     String?
    noteType         String
    text             String
    confidence       String
    language         String
    sourceLinksJson  Json
    aiAssisted       Boolean    @default(false)
    status           NoteStatus @default(draft)
    publishedAt      DateTime?
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt
}

model NoteRating {
    id                    String   @id @default(cuid())
    noteId                String
    userId                String
    ratingValue           String
    ratingWeight          Float    @default(1)
    clusterBucketSnapshot String?
    createdAt             DateTime @default(now())
}

model GovtScheme {
    id                   String   @id @default(cuid())
    title                String
    whoItsFor            String
    benefitSummary       String
    eligibilitySnapshot  String
    learnMoreUrl         String
    locationScope        String
    status               String   @default("active")
    savedCount           Int      @default(0)
    helpCount            Int      @default(0)
    createdAt            DateTime @default(now())
    updatedAt            DateTime @updatedAt
    sources              SchemeSource[]
}

model SchemeSource {
    id        String     @id @default(cuid())
    schemeId  String
    sourceId  String
    scheme    GovtScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
}

model HelpRequest {
    id                String            @id @default(cuid())
    userId            String?
    kind              String
    storyClusterId    String?
    govtSchemeId      String?
    questionText      String
    callbackNumber    String?
    audioFileUrl      String?
    status            HelpRequestStatus @default(pending)
    createdAt         DateTime          @default(now())
    updatedAt         DateTime          @updatedAt
}

model Save {
    id        String   @id @default(cuid())
    userId    String
    clusterId String
    createdAt DateTime @default(now())
}

model AuditLog {
    id          String   @id @default(cuid())
    actorUserId String?
    actionType  String
    entityType  String
    entityId    String
    metadataJson Json
    createdAt   DateTime @default(now())
}

